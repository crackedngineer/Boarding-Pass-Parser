# Environment Variables Template
# Copy this file to .env and fill in the actual values

# Application Settings
APP_NAME="FlightTrackr API"
APP_VERSION="1.0.0"
APP_DESCRIPTION="API for parsing boarding passes and managing user data"
ENVIRONMENT="development"
DEBUG=true
LOG_LEVEL="INFO"

# Database Configuration
SUPABASE_URL="your_supabase_project_url"
SUPABASE_KEY="your_supabase_anon_key"

# OAuth Configuration  
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/auth/callback/google"

# Security Configuration
JWT_SECRET_KEY="your_jwt_secret_key_here"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Configuration
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001,http://localhost:3003"

# File Upload Configuration
MAX_FILE_SIZE_MB=5
ALLOWED_FILE_TYPES="application/pdf"

# External Services
# Add any external service configurations here